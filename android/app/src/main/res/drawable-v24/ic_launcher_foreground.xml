<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive icon foreground — Lyndrix hexagonal shield mark.
  Safe zone: 72dp centered in 108dp canvas → content scaled to fit with 18dp margin each side.
  Background is provided by @color/ic_launcher_background (#0b1120).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Scale the 100-unit logo into the 72dp safe zone with 18dp offset each side. -->
    <!-- Effective transform: translate(18,18) scale(0.72)  -->
    <group
        android:translateX="18"
        android:translateY="18"
        android:scaleX="0.72"
        android:scaleY="0.72">

        <!-- Outer shield -->
        <path
            android:pathData="M50,5 L90,27.5 L90,72.5 L50,95 L10,72.5 L10,27.5 Z"
            android:strokeColor="#3b82f6"
            android:strokeWidth="3"
            android:fillColor="#00000000" />

        <!-- Inner hexagon -->
        <path
            android:pathData="M50,20 L76,35 L76,65 L50,80 L24,65 L24,35 Z"
            android:strokeColor="#475569"
            android:strokeWidth="1.5"
            android:fillColor="#00000000" />

        <!-- Core node -->
        <path
            android:pathData="M50,30 L67.5,40 L67.5,60 L50,70 L32.5,60 L32.5,40 Z"
            android:fillColor="#2563eb"
            android:fillAlpha="0.9" />

        <!-- Center dark circle -->
        <path
            android:pathData="M56,50 A6,6 0 1,1 44,50 A6,6 0 1,1 56,50 Z"
            android:fillColor="#0b1120" />

        <!-- Center white dot -->
        <path
            android:pathData="M52.5,50 A2.5,2.5 0 1,1 47.5,50 A2.5,2.5 0 1,1 52.5,50 Z"
            android:fillColor="#ffffff" />

        <!-- Connection nodes on outer shield vertices -->
        <path android:pathData="M53,5 A3,3 0 1,1 47,5 A3,3 0 1,1 53,5 Z" android:fillColor="#ffffff"/>
        <path android:pathData="M93,27.5 A3,3 0 1,1 87,27.5 A3,3 0 1,1 93,27.5 Z" android:fillColor="#ffffff"/>
        <path android:pathData="M93,72.5 A3,3 0 1,1 87,72.5 A3,3 0 1,1 93,72.5 Z" android:fillColor="#ffffff"/>
        <path android:pathData="M53,95 A3,3 0 1,1 47,95 A3,3 0 1,1 53,95 Z" android:fillColor="#ffffff"/>
        <path android:pathData="M13,72.5 A3,3 0 1,1 7,72.5 A3,3 0 1,1 13,72.5 Z" android:fillColor="#ffffff"/>
        <path android:pathData="M13,27.5 A3,3 0 1,1 7,27.5 A3,3 0 1,1 13,27.5 Z" android:fillColor="#ffffff"/>

        <!-- Routing lines -->
        <path android:pathData="M50,30 L50,5" android:strokeColor="#3b82f6" android:strokeWidth="1.5" android:fillColor="#00000000"/>
        <path android:pathData="M67.5,60 L90,72.5" android:strokeColor="#3b82f6" android:strokeWidth="1.5" android:fillColor="#00000000"/>
        <path android:pathData="M32.5,60 L10,72.5" android:strokeColor="#3b82f6" android:strokeWidth="1.5" android:fillColor="#00000000"/>
    </group>
</vector>
