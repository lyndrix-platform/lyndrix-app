# The Android project now lives in android/ and IS committed (Capacitor convention).
# It carries its own android/.gitignore for build/, .gradle/, local.properties, the copied web
# assets, and the generated capacitor.config.json/plugins. Do NOT add unanchored rules like
# `app/`, `gradle/`, or `build.gradle` here — they would wrongly ignore the committed android/ tree.

# Node / Capacitor CLI tooling
node_modules/

# Python helper artifacts
__pycache__/
*.pyc

# Signing material — never commit. CI restores android.keystore from ANDROID_KEYSTORE_BASE64.
android.keystore
*.keystore
*.jks
keystore-credentials.txt

# Build artifacts
*.apk
*.aab
*.apk.idsig

# IDE
.idea/
*.iml
